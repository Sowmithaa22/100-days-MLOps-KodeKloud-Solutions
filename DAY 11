cd fraud-detection

# Stop Git from tracking the dataset without deleting it from your local disk
git rm --cached data/raw/transactions.csv

# Track the dataset with DVC (this creates data/raw/transactions.csv.dvc and updates data/raw/.gitignore)
dvc add data/raw/transactions.csv

# Stage the new DVC pointer and .gitignore file in Git
gir add data/raw/transactions.csv.dvc data/raw/.gitignore

 Commit the changes to your Git repository
git commit -m "Track transactions dataset with DVC"
